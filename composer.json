{
    "name": "allyouneed/seo",
    "description": "SEO tags to your Statamic website",
    "license": "proprietary",
    "autoload": {
        "psr-4": {
            "AllYouNeed\\Seo\\": "src"
        }
    },
    "require": {
        "php": "^8.3",
        "statamic/cms": "^6.0"
    },
    "extra": {
        "statamic": {
            "name": "All Seo you need",
            "description": "Seo Addon"
        },
        "laravel": {
            "providers": [
                "AllYouNeed\\Seo\\SeoServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pixelfear/composer-dist-plugin": false
        }
    }
}
